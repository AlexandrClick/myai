{
    "mcpServers": {
        "codegraph": {
            "command": "codegraph",
            "args": [
                "serve",
                "--mcp"
            ]
        },
        "code-review-graph": {
            "command": "uvx",
            "args": [
                "code-review-graph",
                "serve"
            ],
            "type": "studio"
        },
        "gitnexus": {
            "command": "npx",
            "args": [
                "-y",
                "gitnexus@1.4.1",
                "mcp"
            ]
        }
    }
}
